)\\\",\\n    \\\"print ( d.get ( terminal.integrated.shellArgs.linux ) )\\\",\\n    \\\"nl -ba /home/ubuntu/.local/bin/env\\\",\\n    \\\"sed -n 1,200p\\\",\\n    \\\"/bin/bash -l -c type code >/dev/null 2>&1; echo CODE_IN_PATH:$?; code --locate-shell-integration-path bash >/dev/null 2>&1; echo CODE_SI:$?\\\",\\n    \\\"code\\\",\\n    \\\"print updated\\\",\\n    \\\"f.write n\\\",\\n    \\\"f.write\\\",\\n    \\\"json.dump d,f,ensure_ascii=False,indent=2\\\",\\n    \\\"json.dump\\\",\\n    \\\"profiles=d.get\\\",\\n    \\\"with open p,w,encoding=utf-8\\\",\\n    \\\"profiles=d.get ( terminal.integrated.profiles.linux,{} )\\\",\\n    \\\"profiles[bash]={path:/bin/bash,icon:terminal-bash}\\\",\\n    \\\"d[terminal.integrated.profiles.linux]=profiles\\\",\\n    \\\"d[terminal.integrated.defaultProfile.linux]=bash\\\",\\n    \\\"d[terminal.integrated.automationProfile.linux]={path:/bin/bash}\\\",\\n    \\\"with open ( p,w,encoding=utf-8 ) as f:\\\",\\n    \\\"json.dump ( d,f,ensure_ascii=False,indent=2 )\\\",\\n    \\\"f.write ( \\\\\\\\n )\\\",\\n    \\\"print ( updated )\\\",\\n    \\\"set -e\\\",\\n    \\\"printf --- USER SETTINGS ---\\\\\\\\n\\\",\\n    \\\"for k in sorted ( d ) :\\\",\\n    \\\"if k.startswith ( terminal.integrated ) or shellArgs in k:\\\",\\n    \\\"print ( f\\\\\\\"{k} = {d[k]}\\\\\\\" )\\\",\\n    \\\"printf \\\\\\\\n--- WORKSPACE .vscode/settings.json ---\\\\\\\\n\\\",\\n    \\\"if [ -f /home/ubuntu/docker/.vscode/settings.json ]\\\",\\n    \\\"then nl -ba /home/ubuntu/docker/.vscode/settings.json\\\",\\n    \\\"sed -n 1,260p\\\",\\n    \\\"else echo not found\\\",\\n    \\\"fi\\\",\\n    \\\"printf \\\\\\\\n--- SEARCH -l in VS Code config dirs ---\\\\\\\\n\\\",\\n    \\\"grep -RIn --exclude-dir=Cache --exclude-dir=CachedData --exclude=*.log -- \\\\\\\"terminal.integrated\\\\\\\\|shellArgs\\\\\\\\|\\\\\\\\-l\\\\\\\" /home/ubuntu/.config/Code/User /home/ubuntu/docker/.vscode 2 > /dev/null\\\",\\n    \\\"set\\\",\\n    \\\"printf n---\\\",\\n    \\\"printf n--- WORKSPACE\\\",\\n    \\\"if [\\\",\\n    \\\"then\\\",\\n    \\\"then nl\\\",\\n    \\\"else\\\",\\n    \\\"else echo\\\",\\n    \\\"else echo not\\\",\\n    \\\"printf n--- SEARCH\\\",\\n    \\\"mv ai-apps/ai-transformer-router ai-apps/transformer-router\\\",\\n    \\\"mv\\\",\\n    \\\"grep -r \\\\\\\"ai-transformer-router\\\\\\\" . --include=\\\\\\\"*.json\\\\\\\" --include=\\\\\\\"*.yml\\\\\\\" --include=\\\\\\\"*.yaml\\\\\\\" --include=\\\\\\\"*.js\\\\\\\" --include=\\\\\\\"*.ts\\\\\\\" --exclude-dir=.git 2 > /dev/null\\\",\\n    \\\"grep -v \\\\\\\"Permission denied\\\\\\\"\\\",\\n    \\\"true\\\",\\n    \\\"cd ai-apps/transformer-router\\\",\\n    \\\"docker compose up -d\\\",\\n    \\\"docker compose up\\\",\\n    \\\"sleep\\\",\\n    \\\"docker ps\\\",\\n    \\\"grep transformer\\\",\\n    \\\"docker stop open-webui\\\",\\n    \\\"docker stop\\\",\\n    \\\"sleep 20\\\",\\n    \\\"docker logs open-webui --tail 10\\\",\\n    \\\"docker logs\\\",\\n    \\\"docker logs open-webui\\\",\\n    \\\"cd ai-apps/litellm\\\",\\n    \\\"docker compose logs litellm\\\",\\n    \\\"tail -20\\\",\\n    \\\"tail\\\",\\n    \\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"docker exec -it litellm-litellm-1 bash -c \\\\\\\"psql -h litellm-postgres -U litellm -d litellm -c \\\\\\\\\\\\\\\"SELECT table_name FROM information_schema.tables WHERE table_schema = public AND table_name LIKE %litellm%\\\",\\n    \\\"docker exec litellm-litellm-postgres-1 psql -U litellm -d litellm -c \\\\\\\"SELECT table_name FROM information_schema.tables WHERE table_schema = 'public';\\\\\\\"\\\",\\n    \\\"docker exec litellm-litellm-postgres-1\\\",\\n    \\\"docker exec litellm-litellm-postgres-1 psql -U litellm -d litellm -c \\\\\\\"SELECT * FROM LiteLLM_SpendLogs ORDER BY created_at DESC LIMIT 10;\\\\\\\"\\\",\\n    \\\"docker exec litellm-litellm-postgres-1 psql -U litellm -d litellm -c \\\\\\\"SELECT * FROM \\\\\\\\\\\\\\\"LiteLLM_SpendLogs\\\\\\\" ORDER BY created_at DESC LIMIT 10;\\\\\\\"\\\",\\n    \\\"docker exec litellm-litellm-postgres-1 psql -U litellm -d litellm -c \\\\\\\"SELECT model, COUNT(*) as count, SUM(spend) as total_spend, AVG(prompt_tokens) as avg_prompt_tokens, AVG(completion_tokens) as avg_completion_tokens, MIN(\\\\\\\\\\\\\\\"startTime\\\\\\\") as first_used, MAX(\\\\\\\\\\\\\\\"startTime\\\\\\\") as last_used FROM \\\\\\\\\\\\\\\"LiteLLM_SpendLogs\\\\\\\" WHERE model IN ('searxng-search', 'searxng/search') GROUP BY model;\\\\\\\"\\\",\\n    \\\"docker exec litellm-litellm-postgres-1 psql -U litellm -d litellm -c \\\\\\\"SELECT * FROM \\\\\\\\\\\\\\\"LiteLLM_SpendLogs\\\\\\\" WHERE model IN ('searxng-search', 'searxng/search') LIMIT 5;\\\\\\\"\\\",\\n    \\\"docker exec litellm-litellm-postgres-1 psql -U litellm -d litellm -c \\\\\\\"SELECT model, COUNT(*) as count, SUM(spend) as total_spend, SUM(prompt_tokens) as total_prompt_tokens, SUM(completion_tokens) as total_completion_tokens FROM \\\\\\\\\\\\\\\"LiteLLM_SpendLogs\\\\\\\" WHERE model IN ('searxng-search', 'searxng/search') GROUP BY model;\\\\\\\"\\\",\\n    \\\"docker exec litellm-litellm-postgres-1 psql -U litellm -d litellm -c \\\\\\\"SELECT model, spend, prompt_tokens, completion_tokens, \\\\\\\\\\\\\\\"startTime\\\\\\\", \\\\\\\\\\\\\\\"endTime\\\\\\\" FROM \\\\\\\\\\\\\\\"LiteLLM_SpendLogs\\\\\\\" WHERE model = 'openai/qwen3-max' AND spend > 0 ORDER BY \\\\\\\\\\\\\\\"startTime\\\\\\\" DESC LIMIT 5;\\\\\\\"\\\",\\n    \\\"curl -s -X GET http://localhost:4000/v1/models -H \\\\\\\"Authorization: Bearer sk-d32c42809dc67dd39c5d770ba4b8362de49fba61330fdb00\\\\\\\"\\\",\\n    \\\"curl -s -X GET glob -H \\\\\\\"Authorization: Bearer sk-d32c42809dc67dd39c5d770ba4b8362de49fba61330fdb00\\\\\\\"\\\",\\n    \\\"docker-compose restart\\\",\\n    \\\"docker-compose restart ollama-proxy\\\",\\n    \\\"docker-compose up -d --build ollama-proxy\\\",\\n    \\\"docker-compose up\\\",\\n    \\\"grep ollama-proxy\\\",\\n    \\\"cd ai-apps/ollama-proxy\\\",\\n    \\\"docker build -t lite