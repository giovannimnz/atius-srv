ump ( config, f, indent=2, ensure_ascii=False )\\\",\\n    \\\"with open ( config_path, w, encoding=utf-8 ) as f:\\\",\\n    \\\"print ( Configuração do provedor litellm não encontrada )\\\",\\n    \\\"print ( Chave de API principal do LiteLLM atualizada com sucesso )\\\",\\n    \\\"config[models][providers][litellm][apiKey] = sk-d32c42809dc67dd39c5d770ba4b8362de49fba61330fdb00\\\",\\n    \\\"if models in config and providers in config[models] and litellm in config[models][providers]:\\\",\\n    \\\"print ( Configuração do openai-whisper-api não encontrada )\\\",\\n    \\\"else:\\\",\\n    \\\"print ( Chave de API atualizada com sucesso no ambiente local )\\\",\\n    \\\"config[skills][entries][openai-whisper-api][env][OPENCLAW_STT_API_KEY] = sk-d32c42809dc67dd39c5d770ba4b8362de49fba61330fdb00\\\",\\n    \\\"if skills in config and entries in config[skills] and openai-whisper-api in config[skills][entries]:\\\",\\n    \\\"config = json.load ( f )\\\",\\n    \\\"with open ( config_path, r, encoding=utf-8 ) as f:\\\",\\n    \\\"config_path = Path ( /home/ubuntu/.openclaw/openclaw.json )\\\",\\n    \\\"python3 -c\\\",\\n    \\\"which\\\",\\n    \\\"which qwen-vision-mcp\\\",\\n    \\\"npm install -g --prefix ~/.local .\\\",\\n    \\\"qwen-vision-mcp\\\",\\n    \\\"cp /home/ubuntu/.openclaw/openclaw.json /home/ubuntu/.openclaw/openclaw.json.backup\\\",\\n    \\\"diff -u /home/ubuntu/.openclaw/openclaw.json openclaw/data/openclaw-config/openclaw.json\\\",\\n    \\\"head -50\\\",\\n    \\\"diff\\\",\\n    \\\"ls -la openclaw/data/openclaw-config/\\\",\\n    \\\"python3 migrate_openclaw_data.py\\\",\\n    \\\"sudo chown\\\",\\n    \\\"sudo chown -R ubuntu:ubuntu openclaw/data/openclaw-config/\\\",\\n    \\\"sudo ls\\\",\\n    \\\"sudo ls -la openclaw/data/openclaw-config/\\\",\\n    \\\"cp divap_v40.pine divap_v41.pine\\\",\\n    \\\"cp divap_v41.pine divap_v42.pine\\\",\\n    \\\"print Telegram bot\\\",\\n    \\\"print Telegram\\\",\\n    \\\"print Primary\\\",\\n    \\\"